# Copy to .env and adjust for local development.

# Postgres — superuser (schema migrations + seed)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/voda_ai_homework

# Postgres — app role with RLS (API runtime)
APP_DATABASE_URL=postgres://voda_app:voda_app@localhost:5432/voda_ai_homework

# Mongo — asset read model
MONGO_URL=mongodb://localhost:27017
MONGO_DB=voda_assets

# Redis — cache, rate limits, BullMQ
REDIS_URL=redis://localhost:6379

# API
PORT=3000

# Auth
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=24h

# Platform provisioning (POST /tenants — header x-admin-key)
PLATFORM_ADMIN_KEY=dev-platform-key-change-me

# Cache
CACHE_TTL_SECONDS=60

# Outbox listener
OUTBOX_POLL_INTERVAL_MS=2000
OUTBOX_BATCH_SIZE=50
OUTBOX_PROCESSING_STALE_SECONDS=300

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Idempotency-Key
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_PROCESSING_TTL_SECONDS=60

# Seed (API entry only — npm run seed ignores SEED_ON_START)
SEED_ON_START=false
SEED_PASSWORD=password123
