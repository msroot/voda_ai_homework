# Privileged connection used for seeding/migrations (creates tables + app role)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/voda_ai_homework

# Restricted connection the running app uses so row-level security is enforced.
# This role is created by seeding (see seed/schema.sql).
APP_DATABASE_URL=postgres://voda_app:voda_app@localhost:5432/voda_ai_homework

# Redis (backs the BullMQ asset-sync queue and the read-model cache)
REDIS_URL=redis://localhost:6379

# MongoDB (separate database the worker syncs assets into)
MONGO_URL=mongodb://localhost:27017
MONGO_DB=voda_assets

# Outbox listener: how often to poll the assets table for status='pending'
OUTBOX_POLL_INTERVAL_MS=2000
OUTBOX_BATCH_SIZE=50

PORT=3000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h

# API rate limit (per authenticated user, per-IP for public routes like login)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Platform admin key for tenant provisioning (POST /tenants). Sent as the
# x-admin-key header. This is a platform-level secret, separate from tenant JWTs.
PLATFORM_ADMIN_KEY=change-me-platform-key

# Set to true to reset and seed the database on app startup
SEED_ON_START=true

# Default password for all seeded users
SEED_PASSWORD=password123
